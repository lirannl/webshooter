{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "firefox",
            "request": "launch",
            "reAttach": true,
            "name": "Debug frontend",
            "url": "https://localhost:8443/",
            "webRoot": "${workspaceFolder}/ui",
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug executable 'webshooter'",
            "cargo": {
                "args": [
                    "build",
                    "--bin=webshooter",
                    "--package=webshooter"
                ],
                "filter": {
                    "name": "webshooter",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
    ]
}