// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "label": "Debug frontend",
    "adapter": "JavaScript",
    "webRoot": "${workspaceFolder}/ui",
    "request": "launch",
    "runtimeExecutable": "/usr/bin/vivaldi-stable",
    "runtimeArgs": ["--ignore-certificate-errors"],
    "type": "pwa-chrome",
    "url": "https://pc:8443",
    "userDataDir": ".zed/chromium_profile",
  },
  {
    "label": "Debug backend",
    "adapter": "CodeLLDB",
    "request": "launch",
    "program": "target/debug/webshooter",
    "build": {
      "command": "cargo",
      "args": ["build", "-p", "webshooter"],
    },
  },
]
